# Flask Configuration
SECRET_KEY=your-secret-key-change-in-production
FLASK_APP=app/main.py
FLASK_ENV=development
DEBUG=True

# Database
DATABASE_URL=postgresql://taskflow:taskflow@db:5432/taskflow
# For local development without Docker:
# DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow

# Redis
REDIS_URL=redis://redis:6379/0

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Product IDs (create these in Stripe Dashboard)
STRIPE_STARTER_PRICE_ID=price_starter
STRIPE_PROFESSIONAL_PRICE_ID=price_professional
STRIPE_ENTERPRISE_PRICE_ID=price_enterprise

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview

# Composio Configuration (Auto-Auth - just set API key!)
COMPOSIO_API_KEY=your-composio-api-key
# Optional: Custom OAuth credentials for specific integrations (not required)
# COMPOSIO_GITHUB_CLIENT_ID=your-github-client-id
# COMPOSIO_GITHUB_CLIENT_SECRET=your-github-client-secret
# COMPOSIO_SLACK_CLIENT_ID=your-slack-client-id
# COMPOSIO_SLACK_CLIENT_SECRET=your-slack-client-secret

# Email Configuration (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Application Settings
APP_NAME=TaskFlow PSA
APP_URL=http://localhost:5000
SUPPORT_EMAIL=support@taskflow.com

# Feature Flags
ENABLE_AI_FEATURES=True
ENABLE_INTEGRATIONS=True